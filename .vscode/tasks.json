{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Git Auto Commit",
      "type": "shell",
      "command": "git add .; git commit -m 'Auto-commit'; git push origin main",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": true,
        "close": false
      },
      "problemMatcher": []
    }
  ]
}
